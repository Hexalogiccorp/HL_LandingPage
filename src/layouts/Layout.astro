---
import AboutUs from "../components/AboutUs/AboutUs.astro";
import ContactForm from "../components/ContactForm/ContactForm.astro";
import Footer from "../components/footer/Footer.astro";
import HeroSection from "../components/HeroSection/HeroSection.astro";
import NavBar from "../components/NavBar/NavBar.astro";
import PortFolio from "../components/PortFolio/PortFolio.astro";
import Services from "../components/OurServices/Services.astro";
import Process from "../components/ProcesSection/Process.astro";

import "./index.css";
import Alert from "../components/Alert/Alert.astro";
import Testimonial from "../components/Testimonial/Testimonial.astro";
import Bubble from "../components/WhatsappBubble/Bubble.astro";

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/webp" href="/logo.webp" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>HEXALOGIC - Desarrollo de Software Personalizado para Empresas</title>
    <meta name="title" content="HEXALOGIC - Desarrollo de Software Personalizado para Empresas" />
    <meta name="description" content="Desarrollamos software a la medida, aplicaciones web y móviles, y soluciones digitales para empresas en Costa Rica y Latinoamérica. Cotiza gratis." />
    <meta name="author" content="Hexalogic" />
    <meta name="keywords" content="desarrollo de software, software a medida, aplicaciones web, desarrollo web, Costa Rica, aplicaciones móviles, UX UI, branding" />
    <link rel="canonical" href="https://hexalogiccorp.com" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://hexalogiccorp.com" />
    <meta property="og:title" content="HEXALOGIC - Desarrollo de Software Personalizado para Empresas" />
    <meta property="og:description" content="Desarrollamos software a la medida, aplicaciones web y móviles, y soluciones digitales para empresas en Costa Rica y Latinoamérica." />
    <meta property="og:image" content="https://hexalogiccorp.com/socialMediaLogo.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content="HEXALOGIC" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://hexalogiccorp.com" />
    <meta name="twitter:title" content="HEXALOGIC - Desarrollo de Software Personalizado para Empresas" />
    <meta name="twitter:description" content="Desarrollamos software a la medida, aplicaciones web y móviles, y soluciones digitales para empresas en Costa Rica y Latinoamérica." />
    <meta name="twitter:image" content="https://hexalogiccorp.com/socialMediaLogo.png" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": ["Organization", "ProfessionalService"],
        "name": "Hexalogic",
        "alternateName": "HEXALOGIC",
        "url": "https://hexalogiccorp.com",
        "logo": {
          "@type": "ImageObject",
          "url": "https://hexalogiccorp.com/logo.webp"
        },
        "image": "https://hexalogiccorp.com/socialMediaLogo.png",
        "description": "Desarrollamos software a la medida, aplicaciones web y móviles, y soluciones digitales para empresas en Costa Rica y Latinoamérica.",
        "email": "hexalogiccorp@gmail.com",
        "telephone": ["+50664832448", "+50685521881"],
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Limón",
          "addressCountry": "CR"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+50685521881",
          "contactType": "customer service",
          "availableLanguage": "Spanish"
        },
        "sameAs": [
          "https://www.facebook.com/profile.php?id=61586903368666",
          "https://www.instagram.com/hexalogiccorp/",
          "https://www.tiktok.com/@hexalogiccorp"
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Servicios de Desarrollo de Software",
          "itemListElement": [
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Desarrollo Web"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Software a la Medida"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Aplicaciones Móviles"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "UX/UI Design"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Branding e Identidad Visual"}},
            {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Consultoría Tecnológica"}}
          ]
        }
      }
    </script>
    <meta name="google-site-verification" content="Vbs23HWe8G9E6YXLwUFCdQX-2hxugYUjrFZRlFl--90" />
  </head>
  <body>
<Bubble phone="50685521881"
  message="Hola, quiero más información sobre sus servicios."
  agentName="HexaBot"
  agentTitle="Disponible ahora"
  previewText="¡Hola! 👋 ¿En qué podemos ayudarte hoy?"
  showAfterMs={3000}
  hideAfterScroll={true}
  position="right"/>
    
    <NavBar />
    <HeroSection />
    <Alert/>
    <Services />
    <Process />
    <Testimonial/>
    <PortFolio />
    <AboutUs />
    <ContactForm/>
    <Footer />
    
  </body>
</html>
