---
import "./testimonialStyle.css";

const testimonials = [
  {
    authorName: "Carlos Mendoza",
    authorRole: "CEO at TechVentures",
    authorInitials: "CM",
    stars: 5,
    quote:
      "El proceso fue fluido desde el inicio. Superaron mis expectativas en cada etapa del desarrollo, entregando algo que realmente refleja nuestra visión.",
    videoUrl: "/nissitec.mp4",
  },
  {
    authorName: "Sofía Ramírez",
    authorRole: "Founder at Lumina Studio",
    authorInitials: "SR",
    stars: 5,
    quote:
      "Un equipo que entiende el negocio antes de escribir una sola línea de código. El resultado habla por sí solo y los tiempos de entrega fueron impecables.",
    videoUrl: "",
  },
  {
    authorName: "Jorge Pereira",
    authorRole: "Director at Nova Agency",
    authorInitials: "JP",
    stars: 5,
    quote:
      "La atención al detalle y la comunicación durante todo el proyecto fue excepcional. Lo recomiendo sin dudarlo a cualquiera que busque calidad real.",
    videoUrl: "",
  },
  {
    authorName: "María García",
    authorRole: "CTO at Digital Hub",
    authorInitials: "MG",
    stars: 5,
    quote:
      "Trabajar con este equipo transformó completamente nuestra presencia digital. Profesionalismo y creatividad en cada paso del proyecto.",
    videoUrl: "",
  },
  {
    authorName: "Luis Torres",
    authorRole: "CEO at StartupX",
    authorInitials: "LT",
    stars: 5,
    quote:
      "Increíble experiencia de principio a fin. Entendieron exactamente lo que necesitábamos y lo ejecutaron a la perfección.",
    videoUrl: "",
  },
];
---

<section id="testimonios" class="ts-section">
  <div class="container">
    <div class="header">
      <h2 class="section-title">
        Nuestros <span class="highlighted-text text-bg-animation"
          >testimonios</span
        >
      </h2>
      <p class="section-description">
        Explora lo que dicen nuestros clientes sobre su experiencia trabajando
        con nosotros y cómo hemos transformado sus ideas en soluciones digitales
        exitosas.
      </p>
      <div class="ts-btns">
        <button class="ts-nav-btn" id="btn-prev" aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path
              d="M11 4L6 9l5 5"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <button class="ts-nav-btn" id="btn-next" aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path
              d="M7 4l5 5-5 5"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="ts-carousel-root">
      <div class="ts-track" id="ts-track">
        {
          testimonials.map((t) => (
            <div class="ts-slide">
              <div class="ts-card-row">
                <video
                  class="ts-person-img"
                  src={t.videoUrl}
                  controls
                  playsinline
                  preload="metadata"
                />
                <div class="ts-card-box">
                  <p class="ts-name">{t.authorName.toUpperCase()}</p>
                  <p class="ts-role">{t.authorRole}</p>
                  <div class="ts-stars">
                    {Array.from({ length: t.stars }).map(() => (
                      <span class="ts-star">★</span>
                    ))}
                  </div>
                  <p class="ts-quote">"{t.quote}"</p>
                  <div class="metrics">
                    <div>
                      <div>

                      </div>
                      Conversión: 25%
                    </div>
                    <div>Entrega en 3 semanas</div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="ts-dots-wrap" id="ts-dots">
      {
        testimonials.map((_, i) => (
          <button
            class={`ts-dot ${i === 0 ? "active" : ""}`}
            data-index={i}
            aria-label={`Ir al testimonio ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initCarrousel } from "./initCarrousel";
  initCarrousel();
</script>
