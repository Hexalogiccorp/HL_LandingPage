---
import AboutUs from "../components/AboutUs/AboutUs.astro";
import ContactForm from "../components/ContactForm/ContactForm.astro";
import Footer from "../components/footer/Footer.astro";
import HeroSection from "../components/HeroSection/HeroSection.astro";
import NavBar from "../components/NavBar/NavBar.astro";
import PortFolio from "../components/PortFolio/PortFolio.astro";
import Services from "../components/OurServices/Services.astro";
import Process from "../components/ProcesSection/Process.astro";

import "./index.css";
import Alert from "../components/Alert/Alert.astro";
import Testimonial from "../components/Testimonial/Testimonial.astro";
import Bubble from "../components/WhatsappBubble/Bubble.astro";

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.webp" />
    <meta name="author" content="Hexalogic" />
    <meta
      name="description"
      content="Hexalogic: Soluciones innovadoras en desarrollo de software a medida para empresas y emprendedores."
    />
    <meta name="category" content="Desarrollo de Software" />
    <meta property="og:title" content="Hexalogic - Desarrollo de Software" />
    <meta
      property="og:description"
      content="Creamos aplicaciones y soluciones digitales personalizadas, ayudando a empresas a potenciar su productividad e innovación."
    />
    <meta property="og:image" content="https://hexalogiccorp.com/socialMediaLogo.png" />
    <meta property="og:url" content="https://hexalogiccorp.com" />
    <meta property="og:type" content="website" />
  
    <meta name="generator" content={Astro.generator} />
    <title>HEXALOGIC</title>
  </head>
  <body>
<Bubble phone="50685521881"
  message="Hola, quiero más información sobre sus servicios."
  agentName="HexaBot"
  agentTitle="Disponible ahora"
  previewText="¡Hola! 👋 ¿En qué podemos ayudarte hoy?"
  showAfterMs={3000}
  hideAfterScroll={true}
  position="right"/>
    
    <NavBar />
    <HeroSection />
    <Alert/>
    <Services />
    <Process />
    <Testimonial/>
    <PortFolio />
    <AboutUs />
    <ContactForm/>
    <Footer />
    
  </body>
</html>
