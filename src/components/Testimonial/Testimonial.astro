---
import "./testimonialStyle.css";

const testimonials = [
  {
    authorName: "Joshua Aguirre Mena",
    authorRole: "CEO at Nissitec",
    authorInitials: "JJ",
    stars: 5,
    quote:
      "Hexalogic nos brindó un servicio excepcional, transformando nuestra visión en un sitio web que ha impulsado nuestro crecimiento y mejorado la experiencia de nuestros clientes.",
    videoUrl: "/nissitec.mp4",
    conversionRate: "2%",
    deliveryTime: "3 semanas"
  },
];
---

<section id="testimonios" class="ts-section">
  <div class="container">
    <div class="header">
      <h2 class="section-title">
        Nuestros <span class="highlighted-text text-bg-animation"
          >testimonios</span
        >
      </h2>
      <p class="section-description">
        Explora lo que dicen nuestros clientes sobre su experiencia trabajando
        con nosotros y cómo hemos transformado sus ideas en soluciones digitales
        exitosas.
      </p>
      <div class="ts-btns">
        <button class="ts-nav-btn" id="btn-prev" aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path
              d="M11 4L6 9l5 5"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
        <button class="ts-nav-btn" id="btn-next" aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <path
              d="M7 4l5 5-5 5"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="ts-carousel-root">
      <div class="ts-track" id="ts-track">
        {
          testimonials.map((t) => (
            <div class="ts-slide">
              <div class="ts-card-row">
                <video
                  class="ts-person-img"
                  src={t.videoUrl}
                  controls
                  playsinline
                  preload="metadata"
                />
                <div class="ts-card-box">
                  <p class="ts-name">{t.authorName.toUpperCase()}</p>
                  <p class="ts-role">{t.authorRole}</p>
                  <div class="ts-stars">
                    {Array.from({ length: t.stars }).map(() => (
                      <span class="ts-star">★</span>
                    ))}
                  </div>
                  <p class="ts-quote">"{t.quote}"</p>
                  <div class="metrics">
                    <div>
                      Conversión: {t.conversionRate}
                    </div>
                    <div>Entrega en {t.deliveryTime}</div>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="ts-dots-wrap" id="ts-dots">
      {
        testimonials.map((_, i) => (
          <button
            class={`ts-dot ${i === 0 ? "active" : ""}`}
            data-index={i}
            aria-label={`Ir al testimonio ${i + 1}`}
          />
        ))
      }
    </div>
  </div>
</section>

<script>
  import { initCarrousel } from "./initCarrousel";
  initCarrousel();
</script>
